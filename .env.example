# ── SUPABASE ──────────────────────────────────
SUPABASE_URL=              # From Supabase project Settings > API > Project URL
SUPABASE_ANON_KEY=         # From Supabase Settings > API > anon public key
SUPABASE_SERVICE_KEY=      # From Supabase Settings > API > service_role key (backend only)
DATABASE_URL=              # postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# ── UPSTASH REDIS ─────────────────────────────
UPSTASH_REDIS_REST_URL=    # From Upstash console > your DB > REST URL
UPSTASH_REDIS_REST_TOKEN=  # From Upstash console > your DB > REST Token

# ── TWILIO ────────────────────────────────────
TWILIO_ACCOUNT_SID=        # From Twilio console > Account Info
TWILIO_AUTH_TOKEN=         # From Twilio console > Account Info
TWILIO_PHONE_NUMBER=       # Your Twilio number (e.g. +918XXXXXXXXX)
TWILIO_WEBHOOK_SECRET=     # Random string you set; used to verify Twilio requests

# ── BHASHINI API ──────────────────────────────
BHASHINI_USER_ID=          # From bhashini.gov.in after registration
BHASHINI_API_KEY=          # From Bhashini ULCA dashboard
BHASHINI_PIPELINE_ID=      # Pipeline ID for Hindi ASR+TTS from Bhashini

# ── FAST2SMS ──────────────────────────────────
FAST2SMS_API_KEY=          # From fast2sms.com dashboard > Dev API

# ── CLOUDFLARE R2 ─────────────────────────────
R2_ACCOUNT_ID=             # From Cloudflare dashboard > R2
R2_ACCESS_KEY_ID=          # R2 API token Access Key ID
R2_SECRET_ACCESS_KEY=      # R2 API token Secret Access Key
R2_BUCKET_NAME=            # Your R2 bucket name (e.g. ration-saathi-audio)
R2_PUBLIC_URL=             # Public URL if bucket is public (optional)

# ── GROQ ──────────────────────────────────────
GROQ_API_KEY=              # From console.groq.com > API Keys (free)

# ── APP SECURITY ──────────────────────────────
ENCRYPTION_KEY=            # 32-byte base64 key: python -c "import secrets,base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
JWT_SECRET_KEY=            # Random 64-char string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── APP CONFIG ────────────────────────────────
ENVIRONMENT=development    # development | staging | production
LOG_LEVEL=INFO
SENTRY_DSN=                # From sentry.io > your project > DSN (leave blank in dev)

# ── MOCK e-PDS (for hackathon demo) ───────────
USE_MOCK_EPDS=true         # Set to true to use mock_data/ fixtures instead of real API
EPDS_API_BASE_URL=         # Real state e-PDS API base URL (if available)
EPDS_API_KEY=              # Real e-PDS API key (if available)
