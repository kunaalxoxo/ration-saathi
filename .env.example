# RATION SAATHI ENVIRONMENT VARIABLES EXAMPLE

# General Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
SENTRY_DSN=

# Database (Supabase / PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# IVR (Twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-token
TWILIO_PHONE_NUMBER=+123...
TWILIO_WEBHOOK_SECRET=your-webhook-secret

# Bhashini (Translation/STT/TTS)
BHASHINI_USER_ID=your-id
BHASHINI_API_KEY=your-key
BHASHINI_PIPELINE_ID=your-pipeline-id

# SMS (Fast2SMS)
FAST2SMS_API_KEY=your-key

# Storage (Cloudflare R2)
R2_ACCOUNT_ID=your-id
R2_ACCESS_KEY_ID=your-key
R2_SECRET_ACCESS_KEY=your-key
R2_BUCKET_NAME=your-bucket
R2_PUBLIC_URL=https://your-bucket-url

# Groq (LLM for transcript parsing)
GROQ_API_KEY=gsk_...

# Security
# ENCRYPTION_KEY must be a 32-byte base64 string
ENCRYPTION_KEY=YWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWFhYWE=
JWT_SECRET_KEY=your-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# e-PDS Settings
USE_MOCK_EPDS=true
EPDS_API_BASE_URL=
EPDS_API_KEY=

# Frontend (for development)
VITE_API_BASE_URL=http://localhost:8000
